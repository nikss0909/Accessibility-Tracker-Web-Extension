PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://mongo:27017/accessibility_tracker
JWT_SECRET=replace-with-a-long-random-secret-from-your-secret-manager
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://your-dashboard-domain.com,chrome-extension://your-extension-id
JSON_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=150
TRUST_PROXY=true
